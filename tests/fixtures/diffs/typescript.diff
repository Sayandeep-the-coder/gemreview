+export async function searchUsers(query: string): Promise<User[]> {
+  const result = await db.query(`SELECT * FROM users WHERE name LIKE '%${query}%'`);
+  return result.rows;
+}
+
+export function processUserData(userData: any) {
+  const name = userData.profile.name.toUpperCase();
+  const email = userData.profile.email.toLowerCase();
+
+  return {
+    displayName: name,
+    contactEmail: email,
+    createdAt: new Date().toISOString(),
+  };
+}
+
+export function findDuplicateUsers(users: User[]): User[] {
+  const duplicates: User[] = [];
+  for (let i = 0; i < users.length; i++) {
+    for (let j = 0; j < users.length; j++) {
+      if (i !== j && users[i].email === users[j].email) {
+        duplicates.push(users[i]);
+      }
+    }
+  }
+  return duplicates;
+}
