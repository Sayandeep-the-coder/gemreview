{
  "name": "gemreview",
  "version": "1.3.1",
  "description": "AI-powered CLI PR review bot using Google Gemini — posts inline comments and a structured summary to GitHub pull requests",
  "author": "Sayandeep",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sayandeep-the-coder/gemreview.git"
  },
  "homepage": "https://github.com/Sayandeep-the-coder/gemreview#readme",
  "bugs": {
    "url": "https://github.com/Sayandeep-the-coder/gemreview/issues"
  },
  "bin": {
    "gemreview": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/",
    "action/dist/",
    "action.yml",
    "prompts/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && npm run build:action",
    "build:action": "cd action && npm install && npx tsup",
    "dev": "tsup --watch",
    "cli": "ts-node src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\" \"action/src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "code-review",
    "gemini",
    "github",
    "ai",
    "pr-review",
    "pull-request",
    "google-gemini",
    "code-quality",
    "security-scanner"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "commonjs",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@inquirer/prompts": "^8.3.2",
    "@octokit/rest": "^22.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "micromatch": "^4.0.8",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@actions/core": "^3.0.0",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "msw": "^2.12.14",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
