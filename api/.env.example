# ── MongoDB ──
MONGODB_URI=your-mongodb-atlas-url

# ── Auth ──
JWT_SECRET=your-jwt-secret-here
ENCRYPTION_KEY=64-char-hex-string-for-aes-256-gcm

# ── GitHub OAuth ──
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_TOKEN=your-github-personal-access-token

# ── Email (Gmail API via Nodemailer OAuth2) ──
GMAIL_USER=your-email@gmail.com
GMAIL_CLIENT_ID=your-gcp-client-id
GMAIL_CLIENT_SECRET=your-gcp-client-secret
GMAIL_REFRESH_TOKEN=your-oauth2-refresh-token

# ── Server ──
PORT=3001
APP_URL=your-deployed-url
ALLOWED_ORIGINS=http://localhost:3001
